{
    "name": "kyvio/mailvio-api",
    "description": "Mailvio API SDK generated from docs/API markdown specifications.",
    "type": "library",
    "keywords": [
        "mailvio",
        "php",
        "sdk",
        "api"
    ],
    "homepage": "https://github.com/KVSocial/mailvio-api",
    "license": "MIT",
    "authors": [
        {
            "name": "Mailvio Developers",
            "homepage": "https://app.mailvio.com/"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5"
    },
    "autoload": {
        "psr-4": {
            "Mailvio\\Api\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mailvio\\Api\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "generate-sdk": "php bin/generate-sdk.php",
        "test": "phpunit"
    }
}
